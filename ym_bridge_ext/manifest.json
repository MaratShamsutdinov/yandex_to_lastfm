{
    "manifest_version": 3,
    "name": "Yandex Music MediaSession Bridge",
    "version": "1.0.0",
    "description": "Reliable Yandex Music bridge with side panel control center",
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "sidePanel"
    ],
    "host_permissions": [
        "https://music.yandex.ru/*",
        "http://127.0.0.1/*",
        "http://localhost/*",
        "https://ws.audioscrobbler.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://music.yandex.ru/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "page.js"
            ],
            "matches": [
                "https://music.yandex.ru/*"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "YM Bridge",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png"
        }
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "options_page": "options.html"
}